{
  "name": "site-analytics",
  "version": "0.1.0",
  "description": "Веб-аналитика: скрипт на сайт, сбор визитов, панель отчётов (SQLite, гео по IP).",
  "private": true,
  "type": "module",
  "scripts": {
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run dashboard:dev\"",
    "dashboard:dev": "vite --config dashboard/vite.config.js",
    "dashboard:build": "vite build --config dashboard/vite.config.js",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "geoip-lite": "^1.4.10",
    "ua-parser-js": "^1.0.39",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}
